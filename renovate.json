{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":automergeDigest",
    ":automergeMinor",
    ":enablePreCommit",
    ":maintainLockFilesMonthly",
    ":rebaseStalePrs",
    ":semanticCommits",
    ":semanticCommitScope(deps)",
    "customManagers:githubActionsVersions",
    "helpers:pinGitHubActionDigestsToSemver"
  ],
  "assignees": ["maxbrunet"],
  "ignorePaths": [],
  "internalChecksFilter": "strict",
  "platformAutomerge": true,
  "packageRules": [
    {
      "description": "One week stability period for Python packages",
      "matchDatasources": ["pypi"],
      "minimumReleaseAge": "7 days"
    },
    {
      "matchPackageNames": ["ruff", "astral-sh/ruff-pre-commit"],
      "groupName": "ruff",
      "minimumReleaseAge": "7 days",
      "versioning": "pep440"
    },
    {
      "matchPackageNames": ["ty", "astral-sh/ty-pre-commit"],
      "groupName": "ty",
      "minimumReleaseAge": "7 days",
      "versioning": "pep440"
    },
    {
      "matchPackageNames": ["astral-sh/uv", "astral-sh/uv-pre-commit"],
      "groupName": "uv",
      "minimumReleaseAge": "7 days",
      "versioning": "pep440"
    }
  ],
  "customManagers": [
    {
      "description": "Update mattermost-preview Docker image",
      "customType": "regex",
      "managerFilePatterns": ["/^tests/scripts/setup-mattermost\\.py$/"],
      "matchStrings": [
        "TAG = os\\.environ\\.get\\(\\s*\"MATTERMOST_VERSION\",\\s*\"(?<currentValue>.+?)(?:@(?<currentDigest>sha256:[a-f0-9]{64}))?\""
      ],
      "depNameTemplate": "docker.io/mattermost/mattermost-preview",
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ]
}
